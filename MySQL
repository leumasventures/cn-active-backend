-- ── USEFUL JOINS ───────────────────────────────────

-- Products with category and supplier
SELECT 
  p.id, p.name, p.sku, p.price, p.stock,
  c.name AS category,
  s.name AS supplier,
  w.name AS warehouse
FROM Product p
LEFT JOIN Category c ON p.categoryId = c.id
LEFT JOIN Supplier s ON p.supplierId = s.id
LEFT JOIN Warehouse w ON p.warehouseId = w.id;

-- Sales with customer and items
SELECT 
  s.id, s.receiptNo, s.invoiceNo, s.total,
  s.paymentStatus, s.paymentMethod, s.date,
  cu.name AS customer
FROM Sale s
LEFT JOIN Customer cu ON s.customerId = cu.id
ORDER BY s.date DESC;

-- Sale items detail
SELECT 
  si.id, si.qty, si.unitPrice, si.discount,
  s.receiptNo,
  p.name AS product
FROM SaleItem si
JOIN Sale s ON si.saleId = s.id
JOIN Product p ON si.productId = p.id;

-- Low stock products
SELECT id, name, sku, stock, lowStockThreshold
FROM Product
WHERE stock <= lowStockThreshold
ORDER BY stock ASC;

-- Outstanding invoices (unpaid credit sales)
SELECT 
  s.invoiceNo, s.total, s.date,
  cu.name AS customer, cu.phone
FROM Sale s
LEFT JOIN Customer cu ON s.customerId = cu.id
WHERE s.paymentStatus = 'unpaid'
ORDER BY s.date ASC;

-- Revenue by day (last 30 days)
SELECT 
  DATE(date) AS day,
  SUM(total) AS revenue,
  COUNT(*) AS transactions
FROM Sale
WHERE date >= DATE_SUB(NOW(), INTERVAL 30 DAY)
  AND type != 'payment'
GROUP BY DATE(date)
ORDER BY day DESC;

-- Top customers by spend
SELECT 
  cu.name, cu.phone,
  SUM(s.total) AS totalSpend,
  COUNT(s.id) AS transactions
FROM Customer cu
JOIN Sale s ON s.customerId = cu.id
GROUP BY cu.id
ORDER BY totalSpend DESC
LIMIT 10;

-- Supplier balances owed
SELECT name, contact, phone, balance
FROM Supplier
WHERE balance > 0
ORDER BY balance DESC;

