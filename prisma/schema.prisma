generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"  // add this if not present
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  active    Boolean  @default(true)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  email         String?  @unique
  phone         String?
  address       String?
  loyaltyPoints Int      @default(0)
  balance       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sales         Sale[]
  creditNotes   CreditNote[]
  quotes        Quote[]
}

model Supplier {
  id        String    @id @default(cuid())
  name      String
  email     String?   @unique
  phone     String?
  address   String?
  balance   Float     @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  purchases Purchase[]
}

model Warehouse {
  id          String    @id @default(cuid())
  name        String
  location    String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  transfersFrom StockTransfer[] @relation("FromWarehouse")
  transfersTo   StockTransfer[] @relation("ToWarehouse")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id                String    @id @default(cuid())
  name              String
  sku               String?   @unique
  barcode           String?   @unique
  description       String?
  price             Float
  costPrice         Float?
  taxRate           Float?
  stock             Int       @default(0)
  lowStockThreshold Int?
  unit              String?
  imageUrl          String?
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id])
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id])
  warehouseId       String?
  warehouse         Warehouse? @relation(fields: [warehouseId], references: [id])
  saleItems         SaleItem[]
  purchaseItems     PurchaseItem[]
  quoteItems        QuoteItem[]
  creditNoteItems   CreditNoteItem[]
  stockTransfers    StockTransfer[]
}

model Sale {
  id            String     @id @default(cuid())
  receiptNo     String     @unique
  customerId    String?
  customer      Customer?  @relation(fields: [customerId], references: [id])
  items         SaleItem[]
  subtotal      Float
  discount      Float      @default(0)
  tax           Float      @default(0)
  total         Float
  paymentMethod String?
  pointsEarned  Int        @default(0)
  pointsRedeemed Int       @default(0)
  note          String?
  createdAt     DateTime   @default(now())
  creditNotes   CreditNote[]
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  qty         Int
  price       Float
  discount    Float   @default(0)
  total       Float
}

model Purchase {
  id          String         @id @default(cuid())
  purchaseNo  String         @unique
  supplierId  String
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  items       PurchaseItem[]
  total       Float
  paidAmount  Float          @default(0)
  note        String?
  createdAt   DateTime       @default(now())
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  qty         Int
  costPrice   Float
  total       Float
}

model Quote {
  id         String      @id @default(cuid())
  quoteNo    String      @unique
  customerId String?
  customer   Customer?   @relation(fields: [customerId], references: [id])
  items      QuoteItem[]
  subtotal   Float
  discount   Float       @default(0)
  tax        Float       @default(0)
  total      Float
  validUntil DateTime?
  note       String?
  status     QuoteStatus @default(PENDING)
  createdAt  DateTime    @default(now())
}

model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Int
  price     Float
  discount  Float   @default(0)
  total     Float
}

model CreditNote {
  id         String           @id @default(cuid())
  creditNo   String           @unique
  customerId String?
  customer   Customer?        @relation(fields: [customerId], references: [id])
  saleId     String?
  sale       Sale?            @relation(fields: [saleId], references: [id])
  items      CreditNoteItem[]
  amount     Float
  reason     String?
  createdAt  DateTime         @default(now())
}

model CreditNoteItem {
  id           String     @id @default(cuid())
  creditNoteId String
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  qty          Int
  price        Float
  total        Float
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Float
  category  String?
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockTransfer {
  id              String    @id @default(cuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  fromWarehouseId String
  fromWarehouse   Warehouse @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  qty             Int
  note            String?
  createdAt       DateTime  @default(now())
}

model Settings {
  id                  String             @id @default("global")
  companyName         String?
  address             String?
  phone               String?
  email               String?
  currency            String             @default("USD")
  taxRate             Float              @default(0)
  lowStockThreshold   Int                @default(10)
  invoicePrefix       String             @default("INV")
  receiptPrefix       String             @default("REC")
  quotePrefix         String             @default("QUO")
  creditNotePrefix    String             @default("CN")
  enableBulkDiscount  Boolean            @default(false)
  loyaltyPointsRate   Float              @default(1)
  loyaltyRedemptionRate Float            @default(0.01)
  nextInvoiceNo       Int                @default(1001)
  nextReceiptNo       Int                @default(5001)
  nextQuoteNo         Int                @default(2001)
  nextCreditNoteNo    Int                @default(4001)
  nextPurchaseNo      Int                @default(3001)
  bulkDiscountTiers   BulkDiscountTier[]
}

model BulkDiscountTier {
  id          String   @id @default(cuid())
  settingsId  String
  settings    Settings @relation(fields: [settingsId], references: [id])
  name        String
  minQty      Int
  maxQty      Int?
  discountPct Float
  active      Boolean  @default(true)
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}